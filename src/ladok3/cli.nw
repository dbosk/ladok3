<<test functions>>=
def test_tolerant_pickle_loads_replaces_missing_optional_handlers(monkeypatch):
  handler = RestorableHandler("cached")
  handler.__class__.__module__ = "optional.handlers"
  original_optional = sys.modules.get("optional")
  original_handlers = sys.modules.get("optional.handlers")
  optional_module = types.ModuleType("optional")
  handlers_module = types.ModuleType("optional.handlers")
  handlers_module.RestorableHandler = RestorableHandler
  optional_module.handlers = handlers_module
  sys.modules["optional"] = optional_module
  sys.modules["optional.handlers"] = handlers_module
  try:
    payload = pickle.dumps(FakeLadokSession([handler]))
  finally:
    if original_optional is None:
      del sys.modules["optional"]
    else:
      sys.modules["optional"] = original_optional
    if original_handlers is None:
      del sys.modules["optional.handlers"]
    else:
      sys.modules["optional.handlers"] = original_handlers

  restored = ladok3.cli.tolerant_pickle_loads(payload)

  handler = restored.session._AutologinSession__handlers[0]
  assert isinstance(handler, ladok3.cli.DroppedAutologinHandler)
  assert handler.missing_module == "optional.handlers"
  assert handler.missing_name == "RestorableHandler"


def test_tolerant_pickle_loads_keeps_core_failures():
  handler = RestorableHandler("cached")
  handler.__class__.__module__ = "ladok3.missing"
  original_module = sys.modules.get("ladok3.missing")
  missing_module = types.ModuleType("ladok3.missing")
  missing_module.RestorableHandler = RestorableHandler
  sys.modules["ladok3.missing"] = missing_module
  try:
    payload = pickle.dumps(FakeLadokSession([handler]))
  finally:
    if original_module is None:
      del sys.modules["ladok3.missing"]
    else:
      sys.modules["ladok3.missing"] = original_module

  with pytest.raises(ModuleNotFoundError):
    ladok3.cli.tolerant_pickle_loads(payload)


def test_drop_unimportable_handlers_warns_and_prunes(monkeypatch):
  dropped = ladok3.cli.dropped_handler_class(
    "optional.handlers", "RestorableHandler")()
  kept = RestorableHandler("kept")
  ls = FakeLadokSession([kept, dropped])
  warnings = []

  monkeypatch.setattr(ladok3.cli, "warn", warnings.append)

  dropped_handlers = ladok3.cli.drop_unimportable_handlers(ls)

  assert dropped_handlers == ["optional.handlers.RestorableHandler"]
  assert ls.session._AutologinSession__handlers == [kept]
  assert warnings == [
    "dropped cached handler optional.handlers.RestorableHandler: "
    "module unavailable"
  ]


def test_restore_ladok_session_retries_with_tolerant_unpickler(monkeypatch,
                                                               tmp_path):
  cache_dir = tmp_path / "cache"
  cache_dir.mkdir()
  cache_file = cache_dir / "LadokSession"
  cache_file.write_bytes(b"encrypted")
  fake_dirs = types.SimpleNamespace(user_cache_dir=str(cache_dir))
  warnings = []

  monkeypatch.setattr(ladok3.cli, "dirs", fake_dirs)
  monkeypatch.setattr(ladok3.cli, "warn", warnings.append)
  monkeypatch.setattr(ladok3.cli, "PBKDF2HMAC",
                      lambda **kwargs: types.SimpleNamespace(
                        derive=lambda password: b"0" * 32))
  monkeypatch.setattr(ladok3.cli.base64,
                      "urlsafe_b64encode",
                      lambda data: b"A" * 44)
  monkeypatch.setattr(ladok3.cli,
                      "Fernet",
                      lambda key: types.SimpleNamespace(
                        decrypt=lambda data: b"pickle-data"))

  calls = []

  def fake_pickle_loads(data):
    calls.append(data)
    raise AttributeError("Can't get attribute 'MissingHandler'")

  restored_ls = FakeLadokSession([
    ladok3.cli.dropped_handler_class(
