import io
import pickle
import sys
import types

import pytest

import ladok3.cli


class RestorableHandler:
  def __init__(self, value):
    self.value = value


class FakeSession:
  def __init__(self, handlers=None):
    self._AutologinSession__handlers = list(handlers or [])


class FakeLadokSession:
  def __init__(self, handlers=None):
    self.session = FakeSession(handlers)


<<test functions>>
